# Copy this file to .env and fill in real values. .env is gitignored.

# MongoDB connection string.
# Local example:  mongodb://127.0.0.1:27017/sparkpos
# Atlas example:  mongodb+srv://USER:PASS@cluster0.xxxxx.mongodb.net/sparkpos
MONGODB_URI=mongodb://127.0.0.1:27017/sparkpos

# Port the Express API listens on.
# Note: avoid 5000 on macOS — it's taken by AirPlay Receiver / Control Center.
PORT=5001
